{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "vivi",
      "camelcase": "Vivi",
      "title": "Vivi",
      "scope": "source.vivi",
      "file-types": [
        "vivi"
      ],
      "injection-regex": "^vivi$",
      "class-name": "TreeSitterVivi",
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Vivi is a hackable modern metaprogramming language with reflective preprocessing.",
    "authors": [
      {
        "name": "Julian Kylander",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/maidnaut/Vivi",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
